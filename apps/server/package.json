{
  "name": "@minimalchat/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:generate && npm run build -w @minimalchat/shared && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma db push",
    "db:check": "tsx src/scripts/initDb.ts",
    "db:policies": "tsx src/scripts/applySupabasePolicies.ts"
  },
  "dependencies": {
    "@minimalchat/shared": "1.0.0",
    "@prisma/client": "6.10.1",
    "@supabase/supabase-js": "^2.108.2",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.32",
    "prisma": "6.10.1",
    "tsx": "^4.20.3"
  }
}
