generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String
  email        String    @unique
  handle       String?   @unique
  avatarUrl    String?
  bio          String    @default("")
  lastSeenAt   DateTime?
  hideLastSeen Boolean   @default(false)
  onlineVisibility   String @default("everyone")
  avatarVisibility   String @default("everyone")
  emailVisibility    String @default("nobody")
  lastSeenVisibility String @default("everyone")
  passwordHash String
  createdAt    DateTime  @default(now())
  sentMessages Message[] @relation("SentMessages")
  received     Message[] @relation("ReceivedMessages")
  reactions    MessageReaction[]
  contactsOwned Contact[] @relation("ContactOwner")
  contactsReceived Contact[] @relation("ContactTarget")
  blocksCreated UserBlock[] @relation("Blocker")
  blocksReceived UserBlock[] @relation("Blocked")
  chatPreferences ChatPreference[] @relation("PreferenceOwner")
  chatPreferencesFor ChatPreference[] @relation("PreferenceTarget")
  spacesCreated Space[] @relation("SpaceOwner")
  spaceMemberships SpaceMember[]
  spaceMessages SpaceMessage[]
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  attachmentUrl  String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  replyToMessageId String?
  sentAt     DateTime @default(now())
  deliveredAt DateTime?
  readAt     DateTime?
  editedAt   DateTime?
  isPinned   Boolean  @default(false)
  isForwarded Boolean @default(false)
  hiddenForSender   Boolean @default(false)
  hiddenForReceiver Boolean @default(false)
  isRead     Boolean  @default(false)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  reactions  MessageReaction[]

  @@index([senderId, receiverId, sentAt])
  @@index([receiverId, senderId, sentAt])
  @@index([replyToMessageId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model Contact {
  id        String   @id @default(cuid())
  ownerId   String
  contactId String
  createdAt DateTime @default(now())
  owner     User     @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contact   User     @relation("ContactTarget", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contactId])
  @@index([ownerId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model ChatPreference {
  id        String   @id @default(cuid())
  ownerId   String
  targetId  String
  muted     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation("PreferenceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  target    User     @relation("PreferenceTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([ownerId, targetId])
  @@index([ownerId])
}

model Space {
  id              String   @id @default(cuid())
  type            String
  title           String
  handle          String?  @unique
  avatarUrl       String?
  description     String   @default("")
  commentsEnabled Boolean  @default(false)
  ownerId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           User     @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         SpaceMember[]
  messages        SpaceMessage[]

  @@index([ownerId])
  @@index([type])
}

model SpaceMember {
  id        String   @id @default(cuid())
  spaceId   String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
  @@index([userId])
}

model SpaceMessage {
  id           String   @id @default(cuid())
  spaceId      String
  senderId     String
  text         String
  kind         String   @default("message")
  parentPostId String?
  sentAt       DateTime @default(now())
  editedAt     DateTime?
  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sender       User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([spaceId, sentAt])
  @@index([parentPostId])
}
