{
  "name": "@minimalchat/desktop",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build -w @minimalchat/shared && tsc -p tsconfig.json && vite build",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "publish:win": "npm run build && electron-builder --win nsis --x64 --publish always",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.minimalchat.desktop",
    "productName": "MinimalChat",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "shp3k",
        "repo": "minimalchat"
      }
    ]
  },
  "dependencies": {
    "@minimalchat/shared": "1.0.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "^4.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "motion": "^12.18.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "electron": "42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
