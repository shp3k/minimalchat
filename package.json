{
  "name": "minimalchat",
  "version": "1.1.2",
  "private": true,
  "description": "MinimalChat desktop messenger built with Electron, React, Express, Socket.IO, Prisma and SQLite.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop",
    "build": "npm run build -w @minimalchat/shared && npm run build -w apps/server && npm run build -w apps/desktop",
    "db:migrate": "npm run db:migrate -w apps/server",
    "db:push": "npm run db:push -w apps/server",
    "db:generate": "npm run db:generate -w apps/server",
    "db:policies": "npm run db:policies -w apps/server",
    "dist:win": "npm run dist:win -w apps/desktop"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
